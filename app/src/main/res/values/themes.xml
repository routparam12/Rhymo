<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Rhymo owns its dark palette. Disabling platform force-dark prevents a
         dark-mode device from recoloring Compose surfaces a second time. -->
    <style name="Theme.Rhymo" parent="android:Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">@color/rhymo_ink</item>
        <item name="android:colorAccent">@color/rhymo_lime</item>
        <item name="android:textColor">@color/rhymo_paper</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowDisablePreview">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/rhymo_ink</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>
</resources>
