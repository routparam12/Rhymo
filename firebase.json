{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "hosting/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/listen",
        "destination": "/listen.html"
      }
    ]
  }
}
